<% content_for(:title) { "Connect Google Account — Steward" } %>

<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
  .card { max-width: 480px; margin: 40px auto; background: #fff; border-radius: 12px; padding: 32px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
  h1 { font-size: 22px; margin: 0 0 8px; }
  p { color: #555; line-height: 1.5; margin: 0 0 20px; }
  label { display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px; }
  input[type="email"] { width: 100%; padding: 10px 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; box-sizing: border-box; }
  input[type="email"]:focus { outline: none; border-color: #4285f4; box-shadow: 0 0 0 2px rgba(66,133,244,0.2); }
  button { width: 100%; padding: 12px; background: #4285f4; color: #fff; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; margin-top: 16px; }
  button:hover { background: #3367d6; }
  .error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: 10px 14px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; }
  .agent-name { color: #4285f4; }
</style>

<div class="card">
  <h1>Connect Your Google Account</h1>
  <p>Link your Google account to <span class="agent-name"><%= @agent.name %></span> so it can access your calendar, email, and drive on your behalf.</p>

  <% if @error %>
    <div class="error"><%= @error %></div>
  <% end %>

  <%= form_tag google_setup_start_path(token: params[:token]), method: :post do %>
    <label for="email">Google email address</label>
    <%= email_field_tag :email, params[:email], placeholder: "you@gmail.com", autofocus: true, required: true %>
    <button type="submit">Continue</button>
  <% end %>
</div>
