<% content_for(:title) { "Connected! — Steward" } %>

<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
  .card { max-width: 480px; margin: 40px auto; background: #fff; border-radius: 12px; padding: 32px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); text-align: center; }
  .checkmark { font-size: 48px; margin-bottom: 16px; }
  h1 { font-size: 22px; margin: 0 0 8px; color: #34a853; }
  p { color: #555; line-height: 1.5; margin: 0 0 16px; }
</style>

<div class="card">
  <div class="checkmark">&#10003;</div>
  <h1>Google Account Connected</h1>
  <p>Your Google account is now linked to <strong><%= @agent.name %></strong>. You can close this page and return to your conversation.</p>
</div>
