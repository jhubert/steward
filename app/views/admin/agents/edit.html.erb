<% content_for(:title) { "Edit #{@agent.name} — Stuart Admin" } %>

<div class="page-header">
  <h1>Edit <%= @agent.name %></h1>
  <%= link_to "Back", admin_agent_path(@agent), class: "btn btn-secondary btn-sm" %>
</div>

<div class="card">
  <%= render "form", url: admin_agent_path(@agent), method: :patch, submit_label: "Save Changes", cancel_path: admin_agent_path(@agent) %>
</div>
