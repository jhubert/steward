<% content_for(:title) { "Add Principal — #{@agent.name} — Steward Admin" } %>

<div class="page-header">
  <h1>Add Principal to <%= @agent.name %></h1>
  <%= link_to "Back", admin_agent_path(@agent), class: "btn btn-secondary btn-sm" %>
</div>

<div class="card">
  <%= form_with url: admin_agent_principals_path(@agent), method: :post, local: true do |f| %>
    <% if @agent_principal.errors.any? %>
      <div class="flash flash-alert">
        <% @agent_principal.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="form-group">
      <label for="agent_principal_user_id">User</label>
      <select name="agent_principal[user_id]" id="agent_principal_user_id" required>
        <option value="">Select a user...</option>
        <% @users.each do |user| %>
          <option value="<%= user.id %>" <%= "selected" if @agent_principal.user_id == user.id %>><%= user.name || user.email || "User ##{user.id}" %></option>
        <% end %>
      </select>
    </div>

    <div class="form-group">
      <label for="agent_principal_display_name">Display Name</label>
      <input type="text" name="agent_principal[display_name]" id="agent_principal_display_name" value="<%= @agent_principal.display_name %>" placeholder="Optional — defaults to user's name">
    </div>

    <div class="form-group">
      <label for="agent_principal_role">Role</label>
      <input type="text" name="agent_principal[role]" id="agent_principal_role" value="<%= @agent_principal.role %>" placeholder="e.g. CEO, CTO, COO">
    </div>

    <div style="margin-top: 16px;">
      <button type="submit" class="btn btn-primary">Add Principal</button>
      <%= link_to "Cancel", admin_agent_path(@agent), class: "btn btn-secondary", style: "margin-left: 8px;" %>
    </div>
  <% end %>
</div>
