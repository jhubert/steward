# Example credentials structure for Steward.
# Copy to credentials.yml.enc via: bin/rails credentials:edit
# Or set the equivalent env vars instead (see .env.example).

anthropic:
  api_key: sk-ant-...

openai:
  api_key: sk-...

telegram:
  bot_token: "123456:ABC-DEF..."

active_record_encryption:
  primary_key: ""
  deterministic_key: ""
  key_derivation_salt: ""
