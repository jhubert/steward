# Steward environment variables
# Copy to .env and fill in values. Env vars take precedence over Rails credentials.

# Required — LLM provider
ANTHROPIC_API_KEY=sk-ant-...

# Optional — embeddings (disabled if blank)
OPENAI_API_KEY=sk-...

# Optional — fallback Telegram bot token (per-agent tokens in DB take precedence)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Active Record Encryption (required if not using Rails credentials)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
